# Backend Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Connection (Atlas)
MONGODB_URI=mongodb://username:password@cluster.mongodb.net:27017/dbname?authSource=admin&replicaSet=replicaset&ssl=true
MONGODB_DB=panel_db

# Frontend URL (for CORS)
FRONTEND_URL=https://panel-pulse.vercel.app

# API Keys
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional: Custom Port for API
# API_PORT=3000

# Optional: Allowed Origins (separate multiple with comma)
# ALLOWED_ORIGIN=https://custom-domain.com
